# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/urbansparklecleaners?schema=public"

# Gmail SMTP (for booking/contact/career email notifications)
# Setup: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Google Maps Embed API Key
NEXT_PUBLIC_GOOGLE_MAPS_KEY="your-google-maps-embed-api-key"

# Site URL
NEXT_PUBLIC_SITE_URL="https://urbansparklecleaners.ca"

# Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Google Tag Manager
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# Admin password (for any protected admin routes)
ADMIN_PASSWORD="your-secure-password-here"
